Vérification des données dans PostgreSQL

hypertension_db=> CREATE TABLE patients_hypertension (
    id SERIAL PRIMARY KEY,
    country VARCHAR(100),
    age INT,
    bmi FLOAT,
    cholesterol INT,
    systolic_bp INT,
    diastolic_bp INT,
    smoking_status VARCHAR(50),
    alcohol_intake FLOAT,
    physical_activity_level VARCHAR(50),
    family_history VARCHAR(10),
    diabetes VARCHAR(10),
    stress_level INT,
    salt_intake FLOAT,
    sleep_duration FLOAT,
    heart_rate INT,
    ldl INT,
    hdl INT,
    triglycerides INT,
    glucose INT,
    gender VARCHAR(20),
    education_level VARCHAR(50),
    employment_status VARCHAR(50),
    hypertension VARCHAR(10)
);


